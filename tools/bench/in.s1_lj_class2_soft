# S1 OMP scaling benchmark: lj/class2/soft
# 864-atom FCC (6x6x6 unit cells), 500 NVE steps

units           lj
atom_style      atomic

lattice         fcc 0.8442
region          box block 0 6 0 6 0 6
create_box      1 box
create_atoms    1 box
mass            1 1.0

velocity        all create 3.0 87287 loop geom

pair_style      lj/class2/soft 1.0 0.5 2.5
pair_coeff      1 1 1.0 1.0 0.5

neighbor        0.3 bin
neigh_modify    every 20 delay 0 check no

fix             1 all nve

thermo          100
run             500
