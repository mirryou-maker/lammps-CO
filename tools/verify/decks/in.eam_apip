units metal
atom_style apip
boundary p p p
lattice fcc 3.615
region box block 0 4 0 4 0 4
create_box 1 box
create_atoms 1 box
mass * 63.546
pair_style eam/apip
pair_coeff * * /home/cyyou68/repos/lammps-co-base/potentials/Cu_smf7.eam
velocity all create 300.0 87287 loop geom
fix 1 all nve
timestep 0.001
thermo 5
thermo_style custom step temp epair etotal press
thermo_modify format float %20.15g
run 20
